# ===== OpenAI-compatible LLM / Embedding =====
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=
EMBEDDING_MODEL=

# Legacy aliases used by the older chat routes.
ARK_API_KEY=
MODEL=
GRADE_MODEL=
BASE_URL=

# ===== Database / Cache =====
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/langchain_app
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_KEY_PREFIX=resumate-agent

# ===== Vector Store =====
VECTOR_STORE_ENABLED=true
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
PROFILE_VECTOR_COLLECTION=candidate_profile_vectors
EMBEDDING_DEVICE=cpu

# ===== PDF OCR =====
PDF_OCR_ENABLED=true
PDF_OCR_MAX_PAGES=8
PDF_OCR_RENDER_SCALE=2.5
PDF_TEXT_MIN_CHARS=30

# ===== Auth =====
JWT_SECRET_KEY=
ADMIN_INVITE_CODE=resumate-agent-admin-2026
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
PASSWORD_PBKDF2_ROUNDS=310000

# ===== API Rate Limit =====
RATE_LIMIT_ENABLED=true

# ===== CORS =====
# Use a comma-separated allowlist in production, for example:
# CORS_ORIGINS=https://yourdomain.com
CORS_ORIGINS=*
BACKEND_CORS_ORIGINS=http://localhost:5173
